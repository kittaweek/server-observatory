  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "description": "% CPU \u0e17\u0e35\u0e48\u0e16\u0e39\u0e01\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e41\u0e22\u0e01\u0e15\u0e32\u0e21 instance \u0e04\u0e33\u0e19\u0e27\u0e13\u0e08\u0e32\u0e01 100% - idle time \u0e16\u0e49\u0e32\u0e2a\u0e39\u0e07\u0e40\u0e01\u0e34\u0e19 80% \u0e15\u0e48\u0e2d\u0e40\u0e19\u0e37\u0e48\u0e2d\u0e07\u0e04\u0e27\u0e23\u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a process \u0e17\u0e35\u0e48\u0e43\u0e0a\u0e49 CPU \u0e2a\u0e39\u0e07"
    },
    {
      "id": 2,
      "title": "Memory Usage (%)",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "description": "% RAM \u0e17\u0e35\u0e48\u0e16\u0e39\u0e01\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e41\u0e22\u0e01\u0e15\u0e32\u0e21 instance \u0e04\u0e33\u0e19\u0e27\u0e13\u0e08\u0e32\u0e01 (Total - Available) / Total \u0e16\u0e49\u0e32\u0e40\u0e01\u0e34\u0e19 90% \u0e2d\u0e32\u0e08\u0e40\u0e23\u0e34\u0e48\u0e21\u0e43\u0e0a\u0e49 SWAP \u0e41\u0e25\u0e30 performance \u0e08\u0e30\u0e0a\u0e49\u0e32\u0e25\u0e07"
    },
    {
      "id": 3,
      "title": "Disk Usage (%)",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max((node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"} - node_filesystem_free_bytes{fstype!~\"tmpfs|overlay\"}) / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"} * 100)",
          "legendFormat": "Disk"
        }
      ],
      "description": "% \u0e1e\u0e37\u0e49\u0e19\u0e17\u0e35\u0e48 disk \u0e2a\u0e39\u0e07\u0e2a\u0e38\u0e14\u0e17\u0e35\u0e48\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e2d\u0e22\u0e39\u0e48\u0e43\u0e19\u0e41\u0e15\u0e48\u0e25\u0e30 instance (\u0e44\u0e21\u0e48\u0e23\u0e27\u0e21 tmpfs \u0e41\u0e25\u0e30 overlay) \u0e16\u0e49\u0e32\u0e40\u0e01\u0e34\u0e19 85% \u0e04\u0e27\u0e23\u0e17\u0e33\u0e04\u0e27\u0e32\u0e21\u0e2a\u0e30\u0e2d\u0e32\u0e14\u0e2b\u0e23\u0e37\u0e2d\u0e02\u0e22\u0e32\u0e22 disk"
    },
    {
      "id": 4,
      "title": "Network I/O",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo\"}[5m])",
          "legendFormat": "RX {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo\"}[5m])",
          "legendFormat": "TX {{device}}"
        }
      ],
      "yaxes": [
        {
          "format": "bytes",
          "label": "bytes/s"
        },
        {
          "format": "short"
        }
      ],
      "description": "\u0e2d\u0e31\u0e15\u0e23\u0e32 network traffic \u0e02\u0e32\u0e40\u0e02\u0e49\u0e32 (receive) \u0e41\u0e25\u0e30\u0e02\u0e32\u0e2d\u0e2d\u0e01 (transmit) \u0e15\u0e48\u0e2d\u0e27\u0e34\u0e19\u0e32\u0e17\u0e35 \u0e44\u0e21\u0e48\u0e23\u0e27\u0e21 loopback interface"
    },
    {
      "id": 5,
      "title": "System Load Average",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
