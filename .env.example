# --- Grafana ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Prometheus ---
PROMETHEUS_RETENTION=15d
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# --- Alert Thresholds ---
ALERT_CPU_THRESHOLD=90
ALERT_MEMORY_THRESHOLD=90
ALERT_DISK_THRESHOLD=85

# --- MS Teams (default alert channel) ---
MSTEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#alerts

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=alert@example.com
SMTP_USER=alert@example.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=ops@example.com

# --- LINE (via webhook proxy) ---
LINE_WEBHOOK_URL=https://your-line-webhook-proxy/notify
