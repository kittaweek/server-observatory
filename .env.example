# =============================================================================
# Server Observatory — Environment Template
# =============================================================================
# Copy this file to `.env` and customize values for your environment.
#   cp .env.example .env
# Only GF_ADMIN_USER and GF_ADMIN_PASSWORD are strictly required; every
# other variable has a safe default applied by the entrypoint scripts.
# =============================================================================
# Server URL Settings
GF_SERVER_DOMAIN=
GF_SERVER_ROOT_URL=

# Google OAuth Settings
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI: ${GF_SERVER_ROOT_URL}/login/google
GF_AUTH_GOOGLE_ENABLED=false
GF_AUTH_GOOGLE_CLIENT_ID=
GF_AUTH_GOOGLE_CLIENT_SECRET=
GF_AUTH_GOOGLE_SCOPES="openid email profile"
GF_AUTH_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GF_AUTH_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GF_AUTH_GOOGLE_API_URL=https://openidconnect.googleapis.com/v1/userinfo
GF_AUTH_GOOGLE_ALLOW_SIGN_UP=true
# Restrict to specific domains (space-separated, e.g. "example.com company.com") or leave blank to allow any Google account
GF_AUTH_GOOGLE_ALLOWED_DOMAINS=
# Optional: auto-assign Grafana role via JMESPath expression (requires GF_SERVER_ROOT_URL to be set)
# GF_AUTH_GOOGLE_ROLE_ATTRIBUTE_PATH=

# Azure AD (Microsoft) Settings
# 1. Go to https://portal.azure.com -> Azure Active Directory -> App registrations -> New registration
# 2. Set Redirect URI: ${GF_SERVER_ROOT_URL}/login/azuread
# 3. Under "Certificates & secrets", create a new client secret
# 4. Under "API permissions", add: openid, email, profile (Microsoft Graph, Delegated)
GF_AUTH_AZUREAD_ENABLED=false
GF_AUTH_AZUREAD_NAME=Microsoft
GF_AUTH_AZUREAD_CLIENT_ID=
GF_AUTH_AZUREAD_CLIENT_SECRET=
# Replace <tenant-id> in the two URLs below with your Directory (tenant) ID from Azure Portal
GF_AUTH_AZUREAD_AUTH_URL="https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize"
GF_AUTH_AZUREAD_TOKEN_URL="https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token"
GF_AUTH_AZUREAD_SCOPES="openid email profile"
GF_AUTH_AZUREAD_ALLOW_SIGN_UP=true
GF_AUTH_AZUREAD_USE_PKCE=true
# Restrict to specific Azure AD groups (comma-separated Object IDs from Azure portal) — leave blank to allow all users in the tenant
GF_AUTH_AZUREAD_ALLOWED_GROUPS=
# Optional: auto-assign Grafana role via JMESPath expression against the token claims
# GF_AUTH_AZUREAD_ROLE_ATTRIBUTE_PATH=

# -----------------------------------------------------------------------------
# Server Identity
# -----------------------------------------------------------------------------
# Friendly name shown as the `nodename` label on dashboards (e.g. Node
# Exporter Full). Useful when running multiple observatory instances.
MONITORING_SERVER_NAME=observatory


# -----------------------------------------------------------------------------
# Grafana (REQUIRED)
# -----------------------------------------------------------------------------
# The stack will refuse to start if these are missing. Use a strong password.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_to_a_strong_password


# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
# How long Prometheus keeps time-series data on disk. Increase if you need
# longer retention, but watch disk usage (see `data/prometheus`).
PROMETHEUS_RETENTION=15d
# How often Prometheus scrapes targets. 15s is a sensible default; lower
# values increase CPU/disk usage proportionally.
PROMETHEUS_SCRAPE_INTERVAL=15s
# How often alerting rules are evaluated. Usually equal to scrape_interval.
PROMETHEUS_EVALUATION_INTERVAL=15s


# -----------------------------------------------------------------------------
# Alert Thresholds
# -----------------------------------------------------------------------------
# Values are percentages (0-100) used by the default alert rules in
# prometheus/rules/alert.rules.yml.
ALERT_CPU_THRESHOLD=90
ALERT_MEMORY_THRESHOLD=90
ALERT_DISK_THRESHOLD=85


# -----------------------------------------------------------------------------
# Extra Monitoring Targets
# -----------------------------------------------------------------------------
# Add remote hosts directly in prometheus/targets/linux.yml (node-exporter :9100)
# or prometheus/targets/windows.yml (windows_exporter :9182).
# Prometheus reloads both files automatically — no restart needed.



# -----------------------------------------------------------------------------
# Alert Channels — uncomment + fill in only what you actually use
# -----------------------------------------------------------------------------

# --- Microsoft Teams (default receiver) ---
MSTEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/REPLACE_ME

# --- Slack ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX
# SLACK_CHANNEL=#alerts

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# TELEGRAM_CHAT_ID=-1000000000000

# --- Email (SMTP) ---
# SMTP_HOST=smtp.gmail.com:587
# SMTP_FROM=alert@example.com
# SMTP_USER=alert@example.com
# SMTP_PASSWORD=change_me_app_password
# ALERT_EMAIL_TO=ops@example.com

# --- LINE (via webhook proxy or n8n) ---
# LINE_WEBHOOK_URL=https://your-webhook-proxy.example.com/notify
# LINE_WEBHOOK_TOKEN=change_me_bearer_token
